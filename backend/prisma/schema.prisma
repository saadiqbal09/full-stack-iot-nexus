generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id        String          @id @default(uuid())
  name      String
  telemetry TelemetryData[]
}

model TelemetryData {
  id        Int      @id @default(autoincrement())
  deviceId  String
  timestamp DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id])
}
